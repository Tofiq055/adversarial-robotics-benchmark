# ════════════════════════════════════════════════════════════════════════
# .env.example — adversarial-robotics-benchmark
# ════════════════════════════════════════════════════════════════════════
#
# HOW TO USE:
#   1. Copy this file to .env in the repo root:
#        cp .env.example .env
#   2. Fill in the variables you actually need (most are OPTIONAL).
#   3. NEVER commit .env to git — it is excluded by .gitignore.
#
# All values below are PLACEHOLDERS. Replace them with your own credentials
# only if you intend to use the corresponding feature.
# ════════════════════════════════════════════════════════════════════════


# ── HuggingFace (OPTIONAL) ──────────────────────────────────────────────
# Required only if you plan to:
#   • Pull a private base model from HF Hub
#   • Push your own fine-tuned model back to HF
# Token format: hf_<40+ chars>. Generate at: https://huggingface.co/settings/tokens
# Leave empty for fully local-only usage.
HUGGINGFACE_API_KEY=

# ── Ollama (DEFAULT shown — change only if non-standard) ────────────────
# Local LLM inference server URL. The default works with the bundled
# docker-compose.yml (a4_ollama container exposes 11434 on host).
OLLAMA_HOST=http://127.0.0.1:11434

# ── Gazebo / GUI (Linux desktop only) ───────────────────────────────────
# Needed only if you want to SEE the Gazebo GUI from inside the container.
# Run `xhost +local:docker` on the host first.
DISPLAY=:0


# ── Docker Mode ──────────────────────────────────────────────────────
# Controls how the sim container starts:
#   "demo"    → auto-launch Gazebo + UR5e simulation on container start
#   "default" → container sleeps, you run commands via docker exec
A4_MODE=default
